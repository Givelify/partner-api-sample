<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Givelify Partner API — Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            gi: {
              orange:         '#F85520',
              dark:           '#1C1924',
              purple:         '#7B5CF4',
              'purple-dark':  '#6A4AE3',
              'purple-light': '#EEE9FF',
              green:          '#00B894',
              bg:             '#F8F8FB',
            }
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="bg-gi-bg text-gi-dark">

  <!-- ── Top bar (fixed, full width) ───────────────────────────────────────── -->
  <header class="fixed top-0 left-0 right-0 h-14 bg-white border-b border-gray-200 flex items-center z-20 px-5">
    <div class="w-52 flex-shrink-0 flex items-center gap-3">
      <img src="/images/logo.svg" alt="Givelify" class="h-7" />
      <span class="text-xs font-bold leading-tight text-gi-orange border-l border-gray-200 pl-3">
        Partner<br>API
      </span>
    </div>
    <div class="flex-1"></div>
    <div class="flex items-center gap-3">
      <% if (locals.orgName) { %>
        <span class="text-sm text-gray-600 hidden sm:block"><%= orgName %></span>
        <div class="w-8 h-8 rounded-full bg-gi-purple flex items-center justify-center text-white text-sm font-semibold select-none">
          <%= orgName.charAt(0).toUpperCase() %>
        </div>
      <% } %>
    </div>
  </header>

  <!-- ── Left sidebar (fixed, below top bar) ───────────────────────────────── -->
  <aside class="fixed top-14 left-0 bottom-0 w-52 bg-white border-r border-gray-200 overflow-y-auto z-10 flex flex-col">
    <nav class="flex-1 py-4 px-2 space-y-0.5">
      <%
        const tabs = [
          {
            href:  '/donations',
            label: 'Donations',
            icon:  '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />'
          },
          {
            href:  '/donors',
            label: 'Donors',
            icon:  '<path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0z" />'
          },
          {
            href:  '/envelopes',
            label: 'Envelopes',
            icon:  '<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />'
          },
          {
            href:  '/organizations',
            label: 'Organizations',
            icon:  '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />'
          },
          {
            href:  '/webhooks',
            label: 'Webhooks',
            icon:  '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5 14.25 2.25 12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />'
          },
          {
            href:  '/settings',
            label: 'Settings',
            icon:  '<path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 0 1 0 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 0 1 0-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" />'
          },
        ];
        tabs.forEach(tab => {
          const active = activeTab === tab.href.replace('/', '');
      %>
        <a href="<%= tab.href %>"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors
                  <%= active
                    ? 'bg-gi-purple-light text-gi-purple'
                    : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900' %>">
          <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <%- tab.icon %>
          </svg>
          <%= tab.label %>
        </a>
      <% }); %>
    </nav>
  </aside>

  <!-- ── Main content (offset right + down to clear fixed bars) ────────────── -->
  <main class="ml-52 mt-14 p-6 min-h-screen bg-gi-bg">
