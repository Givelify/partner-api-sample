<%- include('partials/header', { activeTab: 'organizations' }) %>

<h2 class="text-xl font-semibold mb-4">Organizations</h2>

<% if (error) { %>
  <div class="bg-red-50 border border-red-300 rounded p-4 mb-4 text-red-700">
    <strong><%= error.status ? error.status + ' — ' : '' %></strong><%= error.message %>
    <% if (error.status === 401) { %><a href="/settings" class="underline ml-1">Check your API key in Settings.</a><% } %>
  </div>
<% } else if (!data || data.length === 0) { %>
  <p class="text-gray-500 py-8 text-center">No results found.</p>
<% } else { %>
  <div class="overflow-x-auto">
    <table class="w-full bg-white border border-gray-200 rounded text-sm">
      <thead class="bg-gray-50 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">
        <tr>
          <th class="px-4 py-3">Name</th>
          <th class="px-4 py-3">Type</th>
          <th class="px-4 py-3">City / State</th>
          <th class="px-4 py-3">Phone</th>
          <th class="px-4 py-3">Created</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% data.forEach(org => { %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium"><%= org.name || '—' %></td>
          <td class="px-4 py-3">
            <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">
              <%= org.type || '—' %>
            </span>
          </td>
          <td class="px-4 py-3 text-gray-600"><%= [org.city, org.state].filter(Boolean).join(', ') || '—' %></td>
          <td class="px-4 py-3 text-gray-600"><%= org.phone || '—' %></td>
          <td class="px-4 py-3 text-gray-500"><%= org.created_at || '—' %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('partials/footer') %>
