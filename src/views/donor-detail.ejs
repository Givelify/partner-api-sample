<%- include('partials/header', { activeTab: 'donors' }) %>

<div class="mb-4">
  <a href="/donors" class="text-sm text-blue-700 hover:underline">← Back to Donors</a>
</div>

<h2 class="text-xl font-semibold mb-4">Donor
  <% if (data) { %><span class="font-mono text-base text-gray-400"><%= data.id %></span><% } %>
</h2>

<% if (error) { %>
  <div class="bg-red-50 border border-red-300 rounded p-4 mb-4 text-red-700">
    <strong><%= error.status ? error.status + ' — ' : '' %></strong><%= error.message %>
    <% if (error.status === 401) { %>
      <a href="/settings" class="underline ml-1">Check your API key in Settings.</a>
    <% } %>
  </div>
<% } else if (data) { %>
  <div class="bg-white border border-gray-200 rounded overflow-hidden mb-6">
    <table class="w-full text-sm">
      <tbody class="divide-y divide-gray-100">
        <tr>
          <td class="px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide w-48">ID</td>
          <td class="px-4 py-3 font-mono text-gray-800"><%= data.id %></td>
        </tr>
        <tr>
          <td class="px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Name</td>
          <td class="px-4 py-3 font-medium"><%= data.name || '—' %></td>
        </tr>
        <tr>
          <td class="px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Email</td>
          <td class="px-4 py-3 text-gray-800"><%= data.email || '—' %></td>
        </tr>
        <tr>
          <td class="px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Phone</td>
          <td class="px-4 py-3 text-gray-600"><%= data.phone || '—' %></td>
        </tr>
        <tr>
          <td class="px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Address</td>
          <td class="px-4 py-3 text-gray-600"><%= data.address || '—' %></td>
        </tr>
        <tr>
          <td class="px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">City / State</td>
          <td class="px-4 py-3 text-gray-600"><%= [data.city, data.state].filter(Boolean).join(', ') || '—' %></td>
        </tr>
        <tr>
          <td class="px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Country</td>
          <td class="px-4 py-3 text-gray-600"><%= data.country || '—' %></td>
        </tr>
        <tr>
          <td class="px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">ZIP</td>
          <td class="px-4 py-3 text-gray-600"><%= data.zip || '—' %></td>
        </tr>
        <tr>
          <td class="px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">External ID</td>
          <td class="px-4 py-3 text-gray-500"><%= data.external_id || '—' %></td>
        </tr>
        <tr>
          <td class="px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Created At</td>
          <td class="px-4 py-3 text-gray-600"><%= data.created_at || '—' %></td>
        </tr>
        <tr>
          <td class="px-4 py-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Updated At</td>
          <td class="px-4 py-3 text-gray-600"><%= data.updated_at || '—' %></td>
        </tr>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('partials/debug', { debug }) %>
<%- include('partials/footer') %>
