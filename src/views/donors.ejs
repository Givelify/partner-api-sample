<%- include('partials/header', { activeTab: 'donors' }) %>

<h2 class="text-xl font-semibold mb-4">Donors</h2>

<!-- Filter form -->
<form method="GET" action="/donors" class="bg-white rounded border border-gray-200 p-4 mb-6 grid grid-cols-2 gap-4 md:grid-cols-4">
  <div>
    <label class="block text-xs font-medium text-gray-600 mb-1">Email</label>
    <input type="email" name="email" value="<%= filters.email %>" placeholder="donor@example.com"
           class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm" />
  </div>
  <div>
    <label class="block text-xs font-medium text-gray-600 mb-1">Name (partial match)</label>
    <input type="text" name="name" value="<%= filters.name %>" placeholder="Alice"
           class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm" />
  </div>
  <div>
    <label class="block text-xs font-medium text-gray-600 mb-1">Updated since</label>
    <input type="date" name="updated_since" value="<%= filters.updated_since %>"
           class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm" />
  </div>
  <div class="col-span-2 md:col-span-4 flex gap-2">
    <button type="submit" class="bg-blue-700 text-white px-4 py-1.5 rounded text-sm font-medium hover:bg-blue-800">Apply</button>
    <a href="/donors" class="text-sm text-gray-500 px-4 py-1.5 hover:underline">Clear</a>
  </div>
</form>

<% if (error) { %>
  <div class="bg-red-50 border border-red-300 rounded p-4 mb-4 text-red-700">
    <strong><%= error.status ? error.status + ' — ' : '' %></strong><%= error.message %>
    <% if (error.status === 401) { %>
      <a href="/settings" class="underline ml-1">Check your API key in Settings.</a>
    <% } %>
  </div>
<% } else if (!data || data.length === 0) { %>
  <p class="text-gray-500 py-8 text-center">No results found.</p>
<% } else { %>
  <div class="overflow-x-auto">
    <table class="w-full bg-white border border-gray-200 rounded text-sm">
      <thead class="bg-gray-50 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">
        <tr>
          <th class="px-4 py-3">Name</th>
          <th class="px-4 py-3">Email</th>
          <th class="px-4 py-3">Phone</th>
          <th class="px-4 py-3">City / State</th>
          <th class="px-4 py-3">External ID</th>
          <th class="px-4 py-3">Created</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% data.forEach(donor => { %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium"><%= donor.name || '—' %></td>
          <td class="px-4 py-3 text-gray-600"><%= donor.email || '—' %></td>
          <td class="px-4 py-3 text-gray-600"><%= donor.phone || '—' %></td>
          <td class="px-4 py-3 text-gray-600"><%= [donor.city, donor.state].filter(Boolean).join(', ') || '—' %></td>
          <td class="px-4 py-3 text-gray-500"><%= donor.external_id || '—' %></td>
          <td class="px-4 py-3 text-gray-500"><%= donor.created_at || '—' %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <% if (pagination) { %>
  <div class="flex items-center justify-between mt-4 text-sm text-gray-600">
    <span>Page <%= pagination.current_page %> of <%= pagination.total_pages %></span>
    <div class="flex gap-2">
      <% if (prevQuery) { %><a href="/donors?<%= prevQuery %>" class="px-3 py-1.5 border border-gray-300 rounded hover:bg-gray-100">← Previous</a><% } %>
      <% if (nextQuery) { %><a href="/donors?<%= nextQuery %>" class="px-3 py-1.5 border border-gray-300 rounded hover:bg-gray-100">Next →</a><% } %>
    </div>
  </div>
  <% } %>
<% } %>

<%- include('partials/debug', { debug }) %>
<%- include('partials/footer') %>
