<%- include('partials/header', { activeTab: 'envelopes' }) %>

<h2 class="text-xl font-semibold mb-4">Envelopes</h2>

<!-- Filter form -->
<form method="GET" action="/envelopes" class="bg-white rounded border border-gray-200 p-4 mb-6 grid grid-cols-2 gap-4 md:grid-cols-4">
  <div>
    <label class="block text-xs font-medium text-gray-600 mb-1">Updated since</label>
    <input type="date" name="updated_since" value="<%= filters.updated_since %>"
           class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm" />
  </div>
  <div>
    <label class="block text-xs font-medium text-gray-600 mb-1">Organization UUID</label>
    <input type="text" name="organization_id" value="<%= filters.organization_id %>"
           placeholder="xxxxxxxx-xxxx-..."
           class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm" />
  </div>
  <div class="col-span-2 md:col-span-4 flex gap-2">
    <button type="submit" class="bg-blue-700 text-white px-4 py-1.5 rounded text-sm font-medium hover:bg-blue-800">Apply</button>
    <a href="/envelopes" class="text-sm text-gray-500 px-4 py-1.5 hover:underline">Clear</a>
  </div>
</form>

<% if (error) { %>
  <div class="bg-red-50 border border-red-300 rounded p-4 mb-4 text-red-700">
    <strong><%= error.status ? error.status + ' — ' : '' %></strong><%= error.message %>
    <% if (error.status === 401) { %><a href="/settings" class="underline ml-1">Check your API key in Settings.</a><% } %>
  </div>
<% } else if (!data || data.length === 0) { %>
  <p class="text-gray-500 py-8 text-center">No results found.</p>
<% } else { %>
  <div class="overflow-x-auto">
    <table class="w-full bg-white border border-gray-200 rounded text-sm">
      <thead class="bg-gray-50 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">
        <tr>
          <th class="px-4 py-3">Name</th>
          <th class="px-4 py-3">Description</th>
          <th class="px-4 py-3">External ID</th>
          <th class="px-4 py-3">Organization</th>
          <th class="px-4 py-3">Created</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% data.forEach(env => { %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium"><%= env.name || '—' %></td>
          <td class="px-4 py-3 text-gray-600"><%= env.description || '—' %></td>
          <td class="px-4 py-3 text-gray-500"><%= env.external_id || '—' %></td>
          <td class="px-4 py-3 text-gray-500"><%= env.organization_id || '—' %></td>
          <td class="px-4 py-3 text-gray-500"><%= env.created_at || '—' %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('partials/debug', { debug }) %>
<%- include('partials/footer') %>
