# Copy this file to .env and fill in your values.

# The base URL of the Givelify Partner API (no trailing slash)
API_BASE_URL=https://api-sandbox.givelify.com/v1/

# Your Partner API key — obtain this from your Givelify account
API_KEY=your-api-key-here

# Port the dashboard will listen on
PORT=3000

# Default target URL pre-filled in the Webhooks trigger form (must be HTTPS).
# For local testing, run: ngrok http 3000
# Then set this to your ngrok HTTPS URL + /webhooks/receive
WEBHOOK_RECEIVER_URL=
